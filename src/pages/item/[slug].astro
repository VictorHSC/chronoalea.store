---
import { getCollection, getEntry, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Gallery from '../../components/Gallery.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { STR } from '../../config';
import { slugify, tagUrl, groupUrl, cover } from '../../lib/items';
import { getPhotos } from '../../lib/images';

export async function getStaticPaths() {
  const items = await getCollection('items');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);

// Fotos otimizadas (src/assets); itens antigos caem no campo `photos`.
const photos = getPhotos(item.id);
// og:image precisa ser JPEG absoluto p/ o WhatsApp; gera uma versão 1200px.
let ogImage = cover(item);
if (photos[0]) {
  ogImage = (await getImage({ src: photos[0], format: 'jpeg', width: 1200 })).src;
}

const url = new URL(`/item/${item.id}/`, Astro.site).toString();
const description = [item.data.title, item.data.condition, ...item.data.tags]
  .filter(Boolean)
  .join(' · ');

const groupEntry = item.data.group
  ? await getEntry('groups', item.data.group)
  : undefined;
---
<Base
  title={item.data.title}
  description={description}
  image={ogImage}
  type="article"
>
  <a class="back" href="/">{STR.backHome}</a>

  <div class="item-head">
    <h1>{item.data.title}</h1>
    <StatusBadge status={item.data.status} variant="static" />
  </div>

  {photos.length > 0 ? (
    <div class:list={['gallery', photos.length === 1 && 'single']}>
      {photos.map((img, i) => (
        <div class="shot">
          <Image
            src={img}
            alt={`${item.data.title} (${i + 1}/${photos.length})`}
            widths={[400, 800, 1200, 1600]}
            sizes="(min-width: 640px) 520px, 86vw"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </div>
      ))}
    </div>
  ) : (
    <Gallery photos={item.data.photos} alt={item.data.title} />
  )}

  {(item.data.condition || groupEntry) && (
    <div class="kv">
      {item.data.condition && (
        <span><b>{STR.condition}:</b> {item.data.condition}</span>
      )}
      {groupEntry && (
        <span>
          <b>{STR.group}:</b> <a href={groupUrl(groupEntry.id)}>{groupEntry.data.title}</a>
        </span>
      )}
    </div>
  )}

  {item.data.tags.length > 0 && (
    <div class="chip-row">
      {item.data.tags.map((t) => (
        <a class="chip" href={tagUrl(slugify(t))}>{t}</a>
      ))}
    </div>
  )}

  <div class="actions">
    <WhatsAppButton itemTitle={item.data.title} url={url} />
  </div>

  <div class="prose"><Content /></div>
</Base>
